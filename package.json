{
  "name": "vuna-calc-482",
  "version": "1.0.0",
  "description": "VUNA Calculator with a GitHub Actions + Vercel CI/CD pipeline",
  "private": true,
  "scripts": {
    "test": "jest --coverage",
    "lint": "eslint .",
    "build": "node scripts/build.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "eslint": "^9.13.0",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": ["src/**/*.js"],
    "coverageThreshold": {
      "global": { "branches": 70, "functions": 80, "lines": 80, "statements": 80 }
    }
  }
}
